# API mode (default)
MUAPI_API_KEY=your_muapi_key_here
# Local mode (--mode local)
LLM_PROVIDER=openai           # openai or gemini
OPENAI_API_KEY=your_openai_key_here

OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-2.5-flash
LOCAL_WHISPER_MODEL=base
LOCAL_WHISPER_DEVICE=auto
LOCAL_OUTPUT_DIR=output

# Instagram Settings
# Choose 'instagrapi' (direct login, works locally) or 'api' (official Graph API, requires public URLs)
INSTAGRAM_METHOD=instagrapi

# Credentials for 'instagrapi' method:
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password

# Credentials for official 'api' method:
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token
# (Optional) Public URL prefix where output/ directory is served (required for official API local uploads)
INSTAGRAM_PUBLIC_URL_PREFIX=https://your-public-domain.ngrok-free.app

# Official Instagram OAuth Settings:
INSTAGRAM_APP_ID=your_meta_app_id
INSTAGRAM_APP_SECRET=your_meta_app_secret
INSTAGRAM_REDIRECT_URI=http://localhost:8000/api/instagram/oauth/callback   
INSTAGRAM_OAUTH_SCOPES=instagram_business_basic,instagram_business_manage_messages,instagram_business_manage_comments,instagram_business_content_publish

# Google Drive OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/google/oauth/callback

# Local upload worker
UPLOAD_WORKER_APP_URL=http://localhost:8000
UPLOAD_WORKER_SECRET=
UPLOAD_WORKER_INTERVAL_MS=60000
